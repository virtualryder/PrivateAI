# Copy this file to .env and fill in your values.
# .env is gitignored — never commit actual secrets.

# ── Database ──────────────────────────────────────────────────────────────────
# Railway: set automatically when you add a PostgreSQL service to your project.
# Local dev: leave unset to use SQLite (no setup required).
DATABASE_URL=

# ── AI / LLM ─────────────────────────────────────────────────────────────────
# Required for cloud model fallback (GPT-4o) and optional OpenAI embeddings.
OPENAI_API_KEY=sk-...

# ── Data storage ─────────────────────────────────────────────────────────────
# Root directory for encryption keys, vector stores, and uploads.
# Railway: set to /app/data and mount a Volume at that path.
# Local dev: leave unset (defaults to ./data in the project directory).
DATA_DIR=

# ── Local model (optional) ───────────────────────────────────────────────────
# Ollama host override. Change when running inside Docker.
# Railway: Ollama is not available — leave unset; app falls back to OpenAI.
OLLAMA_HOST=http://localhost:11434
